{
  "type": "object",
  "properties": {
    "overall_status": {
      "type": "string",
      "enum": ["OK", "WARN", "CRIT"]
    },
    "summary": { "type": "string" },
    "regression_detected": { "type": "boolean" },
    "deployment_risk": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "confidence": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "kargo_annotation": { "type": "string" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":    { "type": "string" },
          "status":  { "type": "string", "enum": ["OK", "WARN", "CRIT"] },
          "finding": { "type": "string" },
          "regression": {
            "type": "object",
            "properties": {
              "detected":        { "type": "boolean" },
              "metric":          { "type": "string" },
              "baseline_value":  { "type": "number" },
              "current_value":   { "type": "number" },
              "delta_pct":       { "type": "number" }
            },
            "required": ["detected"]
          },
          "pod_health_finding": { "type": "string" }
        },
        "required": ["name", "status", "finding"]
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "overall_status", "summary", "regression_detected", "deployment_risk",
    "confidence", "kargo_annotation", "services", "recommendations"
  ]
}
